# Copy to .env for local dev and fill in real values. Never commit secrets.

# Weights & Biases API key used to load the production pitch-odds model.
# If unset/invalid, the backend falls back to placeholder odds.
WANDB_API_KEY="replace-me"

# Timezone for computing "today's games" (containers run on UTC). Defaults to
# America/New_York if unset.
APP_TIMEZONE="America/New_York"
