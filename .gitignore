# --- OS / editor ---
.DS_Store
**/.DS_Store

# --- Secrets / env (never commit real secrets) ---
.env
.env.*
!.env.example

# --- Python (backend) ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
# W&B model artifacts downloaded at runtime
backend/artifacts/
backend/wandb/

# --- Node / Next (frontend also has its own .gitignore) ---
node_modules/
.next/
out/
*.tsbuildinfo

# --- Local tooling ---
.claude/
