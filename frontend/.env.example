# Copy to .env.local for local dev and fill in real values. Never commit secrets.

# Postgres connection. Use localhost when running `pnpm dev` on your host;
# use the service name / RDS endpoint when running in a container.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/appdb"

# FastAPI backend base URL (server-side fetches: live games, pitch results).
# localhost on the host; service DNS (e.g. http://backend:8000) in compose.
FAST_API_BACKEND_URL="http://localhost:8000"

# Browser-facing backend WebSocket URL (baked in at build time — NEXT_PUBLIC).
# Host/compose: ws://localhost:8000 (backend port published to the host).
# Production: wss://<your-api-domain>
NEXT_PUBLIC_BACKEND_WS_URL="ws://localhost:8000"

# NextAuth. AUTH_SECRET/NEXTAUTH_SECRET should be a strong random value
# (e.g. `openssl rand -base64 32`). Same value for both.
AUTH_SECRET="replace-me"
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"

# Shared secret guarding POST /api/settle (the settlement worker/cron).
# Generate with `openssl rand -hex 32`.
SETTLE_SECRET="replace-me"
