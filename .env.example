# Root env for docker compose. Copy to .env (gitignored) and fill in.
#   cp .env.example .env

# --- Secrets ---
# NextAuth signing secret (same value for both). Generate: openssl rand -base64 32
AUTH_SECRET=replace-me
NEXTAUTH_SECRET=replace-me

# Guards POST /api/settle (settlement worker). Generate: openssl rand -hex 32
SETTLE_SECRET=replace-me

# Weights & Biases key to load the model. If blank, backend serves placeholder odds.
WANDB_API_KEY=

# --- URLs (browser-facing) ---
# Where the browser reaches the app and the backend WebSocket. For local compose
# these are the published localhost ports. In production use your real domains
# (e.g. https://app.example.com and wss://api.example.com).
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:8000

# --- Backend ---
# Timezone used to compute "today's games" (containers run on UTC).
APP_TIMEZONE=America/New_York
